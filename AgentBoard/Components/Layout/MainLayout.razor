@inherits LayoutComponentBase
@using AgentBoard.Themes

<MudThemeProvider Theme="@AgentBoardTheme.Theme" IsDarkMode="true" DefaultScrollbar="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Style="background-color: #0D1220; border-bottom: 1px solid #1E2D45; backdrop-filter: blur(10px);">
        <MudText Typo="Typo.h5" Style="font-family:'Orbitron',sans-serif; color:#00E5FF; letter-spacing:0.1em; text-shadow: 0 0 20px rgba(0,229,255,0.5);">
            ⬡ AGENT<span style="color:#E0E6F0">BOARD</span>
        </MudText>
        <MudSpacer />
        <nav aria-label="Main navigation" style="display:flex; gap:0.25rem; align-items:center;">
            <NavLink href="/" Match="NavLinkMatch.All" class="app-nav-link" aria-label="Board">Board</NavLink>
            <NavLink href="/projects" class="app-nav-link" aria-label="Projects">Projects</NavLink>
            <NavLink href="/agents" class="app-nav-link" aria-label="Agents">Agents</NavLink>
            <NavLink href="/teams" class="app-nav-link" aria-label="Teams">Teams</NavLink>
        </nav>
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="color:#7B8EA8; letter-spacing:0.15em; text-transform:uppercase;">
            AI Task Coordination
        </MudText>
    </MudAppBar>
    <MudMainContent Style="background: #0A0E1A; min-height: 100vh;">
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>
