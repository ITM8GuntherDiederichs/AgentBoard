@using AgentBoard.Data.Models
@using AgentBoard.Contracts
@using AgentBoard.Services
@inject NavigationManager Nav
@inject TodoService TodoService
@inject ISnackbar Snackbar

<div class="kanban-board">
    @foreach (var status in Enum.GetValues<TodoStatus>())
    {
        var colStatus = status; // capture for closures
        var colTodos  = Todos.Where(t => t.Status == colStatus).ToList();
        var isInProgress  = colStatus == TodoStatus.InProgress;
        var isDragTarget  = _dragTargetStatus == colStatus && _draggingTodo is not null;

        <div class="kanban-column @(isInProgress ? "kanban-column-inprogress" : "") @(isDragTarget ? "kanban-column-drag-over" : "")"
             @ondragover:preventDefault="true"
             @ondragover="@(() => OnColumnDragOver(colStatus))"
             @ondrop="@(() => OnDrop(colStatus))"
             @ondragleave="@(() => OnColumnDragLeave(colStatus))">

            @* Column header *@
            <div class="kanban-column-header @(isInProgress ? "kanban-header-glow" : "")">
                <MudText Typo="Typo.subtitle2"
                         Style="@(isInProgress
                             ? "font-family:'Orbitron',sans-serif; color:#00E5FF; letter-spacing:0.05em;"
                             : "font-family:'Orbitron',sans-serif; letter-spacing:0.05em;")">
                    @GetStatusLabel(colStatus)
                </MudText>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@(isInProgress ? Color.Primary : Color.Default)"
                         Style="min-width:28px; height:22px; justify-content:center; font-size:0.72rem;">
                    @colTodos.Count
                </MudChip>
            </div>

            @* Cards *@
            <div class="kanban-cards">
                @foreach (var todo in colTodos)
                {
                    var isDraggingThis = _draggingTodo?.Id == todo.Id;
                    var capturedTodo   = todo; // capture for closures

                    <MudCard Class="@($"kanban-card{(isDraggingThis ? " kanban-card-dragging" : "")}")"
                             draggable="true"
                             @ondragstart="@(() => OnDragStart(capturedTodo))"
                             @ondragend="OnDragEnd"
                             @onclick="@(() => Nav.NavigateTo($"/todo/{capturedTodo.Id}"))">
                        <MudCardContent Class="pa-3">

                            @* Title *@
                            <MudText Typo="Typo.body2"
                                     Style="font-weight:600; margin-bottom:6px; line-height:1.35; word-break:break-word;">
                                @todo.Title
                            </MudText>

                            @* Priority + Assigned badges *@
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                                <PriorityBadge Priority="@todo.Priority" />
                                @if (!string.IsNullOrEmpty(todo.AssignedTo))
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Icon="@Icons.Material.Filled.Person"
                                             Color="Color.Default"
                                             Class="ma-0"
                                             Style="height:20px; font-size:0.68rem;">
                                        @todo.AssignedTo
                                    </MudChip>
                                }
                            </MudStack>

                            @* Claim indicator *@
                            @if (!string.IsNullOrEmpty(todo.ClaimedBy))
                            {
                                <div style="margin-top:6px;">
                                    <ClaimIndicator Todo="@todo" ShowRelease="false" />
                                </div>
                            }

                        </MudCardContent>
                    </MudCard>
                }

                @* Empty state / drop target when column is empty *@
                @if (!colTodos.Any())
                {
                    <div class="kanban-empty @(isDragTarget ? "kanban-empty-drag-target" : "")">
                        <MudText Typo="Typo.caption" Style="opacity:0.25; letter-spacing:0.08em; text-transform:uppercase;">
                            empty
                        </MudText>
                    </div>
                }
            </div>

        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<Todo> Todos        { get; set; } = [];

    /// <summary>
    /// Invoked after a successful status change via drag-and-drop so the parent
    /// can reload Kanban data immediately (in addition to the SignalR refresh).
    /// </summary>
    [Parameter] public EventCallback OnStatusChanged { get; set; }

    // ── Drag state ────────────────────────────────────────────────────────────

    private Todo?        _draggingTodo;
    private TodoStatus?  _dragTargetStatus;

    /// <summary>Per-column drag-enter counter to avoid false dragleave from child elements.</summary>
    private readonly Dictionary<TodoStatus, int> _dragEnterCounts = new();

    private void OnDragStart(Todo todo)
    {
        _draggingTodo    = todo;
        _dragTargetStatus = null;
        foreach (var s in Enum.GetValues<TodoStatus>()) _dragEnterCounts[s] = 0;
    }

    private void OnDragEnd()
    {
        _draggingTodo    = null;
        _dragTargetStatus = null;
    }

    private void OnColumnDragOver(TodoStatus status)
    {
        // Track the current target column only when it changes (avoids excessive re-renders).
        if (_dragTargetStatus != status)
        {
            _dragTargetStatus = status;
            StateHasChanged();
        }
    }

    private void OnColumnDragLeave(TodoStatus status)
    {
        // Only clear highlight if we are still tracking this column as target.
        // This suppresses the flicker that occurs when the pointer briefly leaves
        // the column div to enter a child element and immediately re-enters.
        // Using a short check: only clear when the target is the current column.
        if (_dragTargetStatus == status)
        {
            _dragTargetStatus = null;
            StateHasChanged();
        }
    }

    private async Task OnDrop(TodoStatus targetStatus)
    {
        if (_draggingTodo is null) return;
        if (_draggingTodo.Status == targetStatus)
        {
            _dragTargetStatus = null;
            return;
        }

        var todo           = _draggingTodo;
        var originalStatus = todo.Status;

        // Optimistic update — move the card immediately in the UI.
        todo.Status       = targetStatus;
        _draggingTodo     = null;
        _dragTargetStatus = null;

        try
        {
            await TodoService.PatchAsync(todo.Id, new PatchTodoRequest { Status = targetStatus });

            // Notify parent so it can reload; SignalR will also fire a reload for all clients.
            await OnStatusChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            // Revert optimistic update on failure.
            todo.Status = originalStatus;
            Snackbar.Add($"Failed to move card: {ex.Message}", Severity.Error);
            StateHasChanged();
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string GetStatusLabel(TodoStatus s) => s switch
    {
        TodoStatus.Pending    => "⏳ Pending",
        TodoStatus.InProgress => "⚡ In Progress",
        TodoStatus.Done       => "✅ Done",
        TodoStatus.Blocked    => "🚫 Blocked",
        _                     => s.ToString()
    };
}
