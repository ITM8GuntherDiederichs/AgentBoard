@using AgentBoard.Data.Models

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-1">
            <MudTextField T="string"
                          Label="Name"
                          @bind-Value="Model.Name"
                          Required="true"
                          RequiredError="Name is required"
                          MaxLength="200"
                          Counter="200"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          aria-label="Skill name" />

            <MudTextField T="string"
                          Label="Markdown content"
                          @bind-Value="Model.Content"
                          Lines="8"
                          MaxLength="10000"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          HelperText="Describe the skill using Markdown"
                          aria-label="Skill content" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" aria-label="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(Model.Name))"
                   aria-label="Save skill">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Skill Model { get; set; } = new();

    void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    void Cancel() => MudDialog.Cancel();
}
