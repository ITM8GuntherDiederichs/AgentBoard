@page "/todo/{Id:guid}"
@using AgentBoard.Contracts
@using AgentBoard.Data.Models
@using AgentBoard.Services
@inject TodoService TodoService
@inject ProjectService ProjectService
@inject AgentService Agents
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Todo Detail — AgentBoard</PageTitle>

<div style="@(_loaded ? "display:none" : "")">
    <MudProgressCircular Indeterminate="true" />
</div>

@if (_loaded && _notFound)
{
    <MudAlert Severity="Severity.Warning">Todo not found.</MudAlert>
    <MudButton Class="mt-2" OnClick='() => Nav.NavigateTo("/")'>Back to Board</MudButton>
}

<div style="@(!_loaded || _notFound ? "display:none" : "")">
    <MudStack Spacing="3" Style="max-width:700px">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Nav.NavigateTo("/")' />
            <MudText Typo="Typo.h5">Edit Todo</MudText>
            <MudSpacer />
            <StatusBadge Status="_todo.Status" />
        </MudStack>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_todo.Title" Label="Title" Required="true" MaxLength="200" />
                <MudTextField @bind-Value="_todo.Description" Label="Description" Lines="4" MaxLength="2000" />
                <MudSelect @bind-Value="_todo.Status" Label="Status" T="TodoStatus">
                    @foreach (var s in Enum.GetValues<TodoStatus>())
                    {
                        <MudSelectItem T="TodoStatus" Value="@s">@s.ToString()</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect @bind-Value="_todo.Priority" Label="Priority" T="TodoPriority">
                    @foreach (var p in Enum.GetValues<TodoPriority>())
                    {
                        <MudSelectItem T="TodoPriority" Value="@p">@p.ToString()</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_todo.AssignedTo" Label="Assigned To" MaxLength="100" />

                @* Project picker — always rendered (not inside @if) to avoid MudSelect/popover crash *@
                <MudSelect T="Guid?" Value="_todo.ProjectId" ValueChanged="OnProjectChanged"
                           Label="Project" Clearable="true" Placeholder="No Project">
                    @foreach (var project in _projects)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)project.Id)">@project.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudDivider />
                <MudText Typo="Typo.subtitle2" Style="color:#94A3B8; letter-spacing:0.05em;">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Class="mr-1" Style="vertical-align:middle;" />
                    Claimed By
                </MudText>

                @* Agent dropdown - always rendered (not inside @if) per MudSelect/popover rules *@
                <MudSelect T="Agent?"
                           Value="_selectedAgent"
                           ValueChanged="OnAgentChanged"
                           Label="Assigned Agent"
                           ToStringFunc="@(a => a == null ? "— Unassigned —" : a.Name)"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="@(_agents.Count == 0 ? "display:none" : "")">
                    <MudSelectItem T="Agent?" Value="@((Agent?)null)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small" Style="opacity:0.5" />
                            <MudText Typo="Typo.body2" Style="opacity:0.6; font-style:italic;">— Unassigned —</MudText>
                        </MudStack>
                    </MudSelectItem>
                    @foreach (var agent in _agents)
                    {
                        var capturedAgent = agent;
                        <MudSelectItem T="Agent?" Value="@((Agent?)capturedAgent)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.body2">@capturedAgent.Name</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Style="@AgentChipStyle(capturedAgent)" Class="ma-0">
                                    @capturedAgent.Type.ToString()
                                </MudChip>
                                @if (!capturedAgent.IsAvailable)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.DoNotDisturb" Size="Size.Small"
                                             Style="opacity:0.4; font-size:0.85rem;" title="Unavailable" />
                                }
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>

                @if (_loaded && _agents.Count == 0)
                {
                    <MudText Typo="Typo.caption" Style="opacity:0.4; font-style:italic;">No agents registered.</MudText>
                }

                @* Show legacy claim info when ClaimedBy is set but no registered agent matches *@
                @if (_loaded && _todo.ClaimedAt.HasValue && _selectedAgent is null && !string.IsNullOrEmpty(_todo.ClaimedBy))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.caption">@_todo.ClaimedBy</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small"
                                       OnClick="ReleaseClaim" aria-label="Release claim" />
                    </MudStack>
                }

                <MudDivider />
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                    <MudButton Variant="Variant.Outlined" OnClick='() => Nav.NavigateTo("/")'>Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-3" Elevation="0">
            <MudText Typo="Typo.caption">
                Created: @_todo.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC &middot;
                Updated: @_todo.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC
            </MudText>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-1" Style="vertical-align:middle;" />
                Audit History
            </MudText>
            @if (_events.Count == 0)
            {
                <MudText Typo="Typo.body2">No audit events recorded yet.</MudText>
            }
            else
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var ev in _events)
                    {
                        <MudTimelineItem Color="@EventColor(ev.EventType)" Size="Size.Small">
                            <ItemContent>
                                <MudStack Spacing="0">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudChip T="string" Size="Size.Small" Color="@EventColor(ev.EventType)" Variant="Variant.Filled">@ev.EventType</MudChip>
                                        @if (!string.IsNullOrEmpty(ev.Actor))
                                        {
                                            <MudText Typo="Typo.caption">by <strong>@ev.Actor</strong></MudText>
                                        }
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption">@ev.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</MudText>
                                    </MudStack>
                                    @if (!string.IsNullOrEmpty(ev.Details))
                                    {
                                        <MudText Typo="Typo.caption" Class="mt-1">@ev.Details</MudText>
                                    }
                                </MudStack>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        </MudPaper>
    </MudStack>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private Todo _todo = new();
    private bool _loaded;
    private bool _notFound;
    private List<TodoEvent> _events = [];
    private List<Project> _projects = [];
    private List<Agent> _agents = [];
    private Agent? _selectedAgent;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await TodoService.GetByIdAsync(Id);
            if (result is not null)
            {
                _todo = result;
                _events = await TodoService.GetEventsAsync(Id, max: 20);
            }
            else
            {
                _notFound = true;
            }

            _projects = await ProjectService.GetAllAsync();

            // Load agents scoped to project (if set) or all agents
            _agents = _todo.ProjectId.HasValue
                ? await Agents.GetForProjectAsync(_todo.ProjectId.Value)
                : await Agents.GetAllAsync();

            // Pre-select the agent that matches the current ClaimedBy name
            _selectedAgent = string.IsNullOrEmpty(_todo.ClaimedBy)
                ? null
                : _agents.FirstOrDefault(a => a.Name == _todo.ClaimedBy);

            _loaded = true;
        }
        catch (Exception ex)
        {
            _notFound = true;
            _loaded = true;
            Snackbar.Add($"Error loading todo: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Called when the project picker value changes.
    /// Immediately PATCHes the todo with the new projectId and reloads the agent list.
    /// </summary>
    private async Task OnProjectChanged(Guid? projectId)
    {
        _todo.ProjectId = projectId;
        try
        {
            var patch = projectId.HasValue
                ? new PatchTodoRequest { ProjectId = projectId }
                : new PatchTodoRequest { ClearProjectId = true };
            await TodoService.PatchAsync(_todo.Id, patch);

            var projectName = projectId.HasValue
                ? _projects.FirstOrDefault(p => p.Id == projectId)?.Name ?? "project"
                : "No Project";
            Snackbar.Add($"Project set to \"{projectName}\".", Severity.Success);

            // Reload agents scoped to the new project
            _agents = projectId.HasValue
                ? await Agents.GetForProjectAsync(projectId.Value)
                : await Agents.GetAllAsync();

            // Re-validate selected agent against updated list
            if (_selectedAgent is not null && !_agents.Any(a => a.Id == _selectedAgent.Id))
                _selectedAgent = null;

            _events = await TodoService.GetEventsAsync(Id, max: 20);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update project: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Called when the user selects (or clears) an agent from the dropdown.
    /// Immediately PATCHes the todo's ClaimedBy field.
    /// </summary>
    private async Task OnAgentChanged(Agent? agent)
    {
        _selectedAgent = agent;
        try
        {
            PatchTodoRequest patch;
            string message;

            if (agent is null)
            {
                patch = new PatchTodoRequest { ClearClaimedBy = true };
                _todo.ClaimedBy = null;
                _todo.ClaimedAt = null;
                _todo.ClaimExpiresAt = null;
                message = "Claim released.";
            }
            else
            {
                patch = new PatchTodoRequest { ClaimedBy = agent.Name };
                _todo.ClaimedBy = agent.Name;
                _todo.ClaimedAt = DateTime.UtcNow;
                _todo.ClaimExpiresAt = null;
                message = $"Assigned to \"{agent.Name}\".";
            }

            await TodoService.PatchAsync(_todo.Id, patch);
            Snackbar.Add(message, Severity.Success);
            _events = await TodoService.GetEventsAsync(Id, max: 20);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update assignment: {ex.Message}", Severity.Error);
        }
    }

    private async Task Save()
    {
        var request = new UpdateTodoRequest
        {
            Title = _todo.Title,
            Description = _todo.Description,
            Status = _todo.Status,
            Priority = _todo.Priority,
            AssignedTo = _todo.AssignedTo
        };
        await TodoService.UpdateAsync(_todo.Id, request);
        Snackbar.Add("Todo saved", Severity.Success);
        Nav.NavigateTo("/");
    }

    private async Task ReleaseClaim()
    {
        await TodoService.ReleaseClaimAsync(_todo.Id);
        var updated = await TodoService.GetByIdAsync(_todo.Id);
        if (updated is not null) _todo = updated;
        _selectedAgent = null;
        _events = await TodoService.GetEventsAsync(Id, max: 20);
        Snackbar.Add("Claim released", Severity.Info);
    }

    /// <summary>Returns the cyberpunk-theme inline style for an agent type chip.</summary>
    private static string AgentChipStyle(Agent agent) => agent.Type switch
    {
        AgentType.AI    => "border-color:#00E5FF; color:#00E5FF; height:18px; font-size:0.65rem;",
        AgentType.Human => "border-color:#B388FF; color:#B388FF; height:18px; font-size:0.65rem;",
        _               => "height:18px; font-size:0.65rem;"
    };

    private static Color EventColor(string eventType) => eventType switch
    {
        "Created"  => Color.Success,
        "Updated"  => Color.Info,
        "Claimed"  => Color.Warning,
        "Released" => Color.Default,
        "Deleted"  => Color.Error,
        _          => Color.Default
    };
}

