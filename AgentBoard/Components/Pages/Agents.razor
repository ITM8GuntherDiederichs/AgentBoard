@page "/agents"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AgentBoard.Contracts
@using AgentBoard.Data.Models
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Agents — AgentBoard</PageTitle>

@if (_initError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load agents: @_initError</MudAlert>
}

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4" Style="font-family:'Orbitron',sans-serif; color:#00E5FF; letter-spacing:0.05em; text-shadow: 0 0 15px rgba(0,229,255,0.4);">
            ⬡ AGENTS
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   aria-label="Create new agent"
                   OnClick="OpenCreateDialog">New Agent</MudButton>
    </MudStack>

    @if (_loading)
    {
        <div class="agents-grid">
            @for (int i = 0; i < 6; i++)
            {
                <MudPaper Class="agent-card-skeleton" Elevation="0">
                    <MudSkeleton Animation="Animation.Wave" Height="24px" Width="55%" />
                    <MudSkeleton Animation="Animation.Wave" Height="20px" Width="30%" Class="mt-2" />
                    <MudSkeleton Animation="Animation.Wave" Height="16px" Class="mt-3" />
                    <MudSkeleton Animation="Animation.Wave" Height="16px" Width="75%" Class="mt-1" />
                </MudPaper>
            }
        </div>
    }
    else if (_agents.Count == 0 && _initError is null)
    {
        <MudPaper Class="pa-8" Elevation="0"
                  Style="background:#0D1220; border:1px solid #1E2D45; border-radius:8px; text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy"
                     Style="font-size:4rem; color:#1E2D45; display:block; margin:0 auto 1rem;" />
            <MudText Typo="Typo.h6" Style="color:#7B8EA8;">No agents yet</MudText>
            <MudText Style="color:#4A5568; margin-top:0.5rem;">
                Register your first AI or human agent to get started.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="mt-4"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">New Agent</MudButton>
        </MudPaper>
    }
    else
    {
        <div class="agents-grid" role="list" aria-label="Agent list">
            @foreach (var agent in _agents)
            {
                <div class="agent-card" role="listitem">
                    <div class="agent-card-header">
                        <span class="agent-name">@agent.Name</span>
                        <div class="agent-card-actions">
                            <MudTooltip Text="Edit agent">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Style="color:#00E5FF"
                                               aria-label="@($"Edit {agent.Name}")"
                                               OnClick="@(() => OpenEditDialog(agent))" />
                            </MudTooltip>
                            <MudTooltip Text="Delete agent">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               aria-label="@($"Delete {agent.Name}")"
                                               OnClick="@(() => DeleteAgent(agent))" />
                            </MudTooltip>
                        </div>
                    </div>

                    <div class="agent-card-chips">
                        @if (agent.Type == AgentType.AI)
                        {
                            <MudChip T="string" Size="Size.Small" Class="chip-ai" aria-label="Type: AI">AI</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Class="chip-human" aria-label="Type: Human">Human</MudChip>
                        }

                        @if (agent.IsAvailable)
                        {
                            <span class="availability-badge available" role="status" aria-label="Status: Available">
                                <span class="dot dot-available" aria-hidden="true"></span>
                                Available
                            </span>
                        }
                        else
                        {
                            <span class="availability-badge offline" role="status" aria-label="Status: Offline">
                                <span class="dot dot-offline" aria-hidden="true"></span>
                                Offline
                            </span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(agent.Description))
                    {
                        <p class="agent-description">@Truncate(agent.Description, 120)</p>
                    }
                    else
                    {
                        <p class="agent-description no-description">No description</p>
                    }

                    @* ── Skills section ─────────────────────────────────────────── *@
                    <div class="agent-skills-section" aria-label="@($"Skills for {agent.Name}")">
                        <div class="agent-skills-header">
                            <span class="agent-skills-label">SKILLS</span>
                            <MudTooltip Text="Add skill">
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline"
                                               Size="Size.Small"
                                               Style="color:#B388FF; margin:-4px -4px 0 0"
                                               aria-label="@($"Add skill to {agent.Name}")"
                                               OnClick="@(() => ToggleAddSkill(agent.Id))" />
                            </MudTooltip>
                        </div>

                        @* Assigned skill chips *@
                        @if (_agentSkills.TryGetValue(agent.Id, out var skills) && skills.Count > 0)
                        {
                            <div class="agent-skills-chips" role="list" aria-label="Assigned skills">
                                @foreach (var skill in skills)
                                {
                                    <div class="skill-chip-wrapper" role="listitem">
                                        <span class="skill-chip" aria-label="@skill.Name">@skill.Name</span>
                                        <button class="skill-chip-remove"
                                                aria-label="@($"Remove skill {skill.Name}")"
                                                @onclick="@(() => RemoveSkillAsync(agent.Id, skill.Id))">×</button>
                                    </div>
                                }
                            </div>
                        }
                        else if (_agentSkills.ContainsKey(agent.Id))
                        {
                            <span class="agent-skills-empty">No skills assigned</span>
                        }

                        @* Add skill panel — MudSelect always rendered, toggled via display:none (MudBlazor v9 rule) *@
                        <div style="@(_showAddSkill.GetValueOrDefault(agent.Id) ? "display:block; margin-top:0.5rem" : "display:none")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudSelect T="Guid"
                                           @bind-Value="_skillToAdd[agent.Id]"
                                           Label="Select skill"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           Margin="Margin.Dense"
                                           Style="flex:1; min-width:0"
                                           aria-label="Select skill to add">
                                    @foreach (var skill in GetAvailableSkills(agent.Id))
                                    {
                                        <MudSelectItem T="Guid" Value="@skill.Id">@skill.Name</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Style="background:#B388FF; color:#0D0D1A; font-weight:700; flex-shrink:0"
                                           OnClick="@(() => AddSkillAsync(agent.Id))"
                                           Disabled="@(_skillToAdd.GetValueOrDefault(agent.Id) == Guid.Empty)"
                                           aria-label="Confirm add skill">Add</MudButton>
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small"
                                               Style="color:#7B8EA8"
                                               aria-label="Cancel add skill"
                                               OnClick="@(() => ToggleAddSkill(agent.Id))" />
                            </MudStack>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</MudStack>

@code {
    private List<Agent> _agents = [];
    private bool _loading = true;
    private string? _initError;

    // ── Skills state ────────────────────────────────────────────────────────
    private List<Skill> _allSkills = [];
    private Dictionary<Guid, List<Skill>> _agentSkills = [];
    private Dictionary<Guid, Guid> _skillToAdd = [];
    private Dictionary<Guid, bool> _showAddSkill = [];

    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAgentsAsync();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _initError = ex.Message;
            _loading = false;
        }
    }

    private async Task LoadAgentsAsync()
    {
        _loading = true;
        try
        {
            var ct = _cts.Token;

            var agents = await Http.GetFromJsonAsync<List<Agent>>("api/agents", ct);
            _agents = agents ?? [];

            // Load all available skills for the add-skill dropdown
            var allSkills = await Http.GetFromJsonAsync<List<Skill>>("api/skills", ct);
            _allSkills = allSkills ?? [];

            // Load assigned skills for every agent in parallel
            _agentSkills.Clear();
            _skillToAdd.Clear();
            _showAddSkill.Clear();

            var skillTasks = _agents.Select(async agent =>
            {
                try
                {
                    var assigned = await Http.GetFromJsonAsync<List<Skill>>($"api/agents/{agent.Id}/skills", ct);
                    return (agent.Id, skills: assigned ?? []);
                }
                catch (OperationCanceledException) { throw; }
                catch
                {
                    return (agent.Id, skills: new List<Skill>());
                }
            });

            var results = await Task.WhenAll(skillTasks);
            foreach (var (agentId, skills) in results)
            {
                _agentSkills[agentId] = skills;
                _skillToAdd[agentId] = Guid.Empty;
                _showAddSkill[agentId] = false;
            }
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            _initError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose() => _cts.Cancel();

    private async Task OpenCreateDialog()
    {
        var model = new Agent { IsAvailable = true };
        var parameters = new DialogParameters<AgentDialog> { { x => x.Model, model } };
        var dialog = await DialogService.ShowAsync<AgentDialog>("New Agent", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Agent created })
        {
            try
            {
                var response = await Http.PostAsJsonAsync("api/agents", created);
                response.EnsureSuccessStatusCode();
                Snackbar.Add("Agent created", Severity.Success);
                await LoadAgentsAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating agent: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(Agent agent)
    {
        var model = new Agent
        {
            Id          = agent.Id,
            Name        = agent.Name,
            Type        = agent.Type,
            Description = agent.Description,
            Instructions = agent.Instructions,
            IsAvailable = agent.IsAvailable,
            CreatedAt   = agent.CreatedAt,
            UpdatedAt   = agent.UpdatedAt
        };

        var parameters = new DialogParameters<AgentDialog> { { x => x.Model, model } };
        var dialog = await DialogService.ShowAsync<AgentDialog>("Edit Agent", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Agent updated })
        {
            try
            {
                var patch = new AgentPatch(
                    updated.Name,
                    updated.Description,
                    updated.Type,
                    updated.IsAvailable,
                    Instructions: updated.Instructions,
                    ClearInstructions: updated.Instructions is null);

                var response = await Http.PatchAsJsonAsync($"api/agents/{updated.Id}", patch);
                response.EnsureSuccessStatusCode();
                Snackbar.Add("Agent updated", Severity.Success);
                await LoadAgentsAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating agent: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteAgent(Agent agent)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Delete \"{agent.Name}\"? This cannot be undone." },
            { x => x.ButtonText,  "Delete" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            try
            {
                var response = await Http.DeleteAsync($"api/agents/{agent.Id}");
                response.EnsureSuccessStatusCode();
                Snackbar.Add("Agent deleted", Severity.Success);
                await LoadAgentsAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting agent: {ex.Message}", Severity.Error);
            }
        }
    }

    private static string Truncate(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length <= maxLength ? text : text[..maxLength] + "…";
    }

    // ── Skills helpers ──────────────────────────────────────────────────────

    private IEnumerable<Skill> GetAvailableSkills(Guid agentId)
    {
        var assigned = _agentSkills.GetValueOrDefault(agentId) ?? [];
        var assignedIds = assigned.Select(s => s.Id).ToHashSet();
        return _allSkills.Where(s => !assignedIds.Contains(s.Id));
    }

    private void ToggleAddSkill(Guid agentId)
    {
        _showAddSkill[agentId] = !_showAddSkill.GetValueOrDefault(agentId);
        _skillToAdd[agentId] = Guid.Empty;
    }

    private async Task AddSkillAsync(Guid agentId)
    {
        var skillId = _skillToAdd.GetValueOrDefault(agentId);
        if (skillId == Guid.Empty) return;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/agents/{agentId}/skills", new { skillId });
            response.EnsureSuccessStatusCode();

            // Update local state — find the skill object and add it
            var skill = _allSkills.FirstOrDefault(s => s.Id == skillId);
            if (skill is not null)
            {
                _agentSkills[agentId].Add(skill);
            }
            _skillToAdd[agentId] = Guid.Empty;
            _showAddSkill[agentId] = false;
            Snackbar.Add("Skill added", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding skill: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveSkillAsync(Guid agentId, Guid skillId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/agents/{agentId}/skills/{skillId}");
            response.EnsureSuccessStatusCode();

            // Update local state
            if (_agentSkills.TryGetValue(agentId, out var list))
                list.RemoveAll(s => s.Id == skillId);

            Snackbar.Add("Skill removed", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error removing skill: {ex.Message}", Severity.Error);
        }
    }
}
