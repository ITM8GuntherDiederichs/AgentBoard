@page "/skills"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AgentBoard.Data.Models
@using AgentBoard.Contracts
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Skills — AgentBoard</PageTitle>

@if (_initError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">Failed to load skills: @_initError</MudAlert>
}

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4" Style="font-family:'Orbitron',sans-serif; color:#00E5FF; letter-spacing:0.05em; text-shadow: 0 0 15px rgba(0,229,255,0.4);">
            ⬡ SKILLS
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   aria-label="Create new skill"
                   OnClick="OpenCreateDialog">New Skill</MudButton>
    </MudStack>

    @if (_loading)
    {
        <div class="skills-grid">
            @for (int i = 0; i < 6; i++)
            {
                <div class="skill-card-skeleton">
                    <MudSkeleton Animation="Animation.Wave" Height="24px" Width="60%" />
                    <MudSkeleton Animation="Animation.Wave" Height="16px" Class="mt-3" />
                    <MudSkeleton Animation="Animation.Wave" Height="16px" Width="80%" Class="mt-1" />
                    <MudSkeleton Animation="Animation.Wave" Height="16px" Width="50%" Class="mt-1" />
                </div>
            }
        </div>
    }
    else if (_skills.Count == 0 && _initError is null)
    {
        <MudPaper Class="pa-8" Elevation="0"
                  Style="background:#0D1220; border:1px solid #1E2D45; border-radius:8px; text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.Psychology"
                     Style="font-size:4rem; color:#1E2D45; display:block; margin:0 auto 1rem;" />
            <MudText Typo="Typo.h6" Style="color:#7B8EA8;">No skills yet</MudText>
            <MudText Style="color:#4A5568; margin-top:0.5rem;">
                Create your first skill to define reusable agent capabilities.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="mt-4"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">New Skill</MudButton>
        </MudPaper>
    }
    else
    {
        <div class="skills-grid">
            @foreach (var skill in _skills)
            {
                var isFilesExpanded = _expandedFilesSkillId == skill.Id;
                var fileCount = _skillFiles.TryGetValue(skill.Id, out var files) ? files.Count : 0;
                var isUploadingForSkill = _uploadingSkillId == skill.Id;

                <div class="skill-card @(isFilesExpanded ? "skill-card--expanded" : "")">
                    <!-- Card Header -->
                    <div class="skill-card-header">
                        <span class="skill-name">@skill.Name</span>
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <!-- File count badge (clickable to toggle files panel) -->
                            <span class="files-badge"
                                  role="button"
                                  tabindex="0"
                                  aria-label="@($"Toggle files for {skill.Name}")"
                                  aria-expanded="@isFilesExpanded.ToString().ToLower()"
                                  @onclick="@(() => ToggleFilesAsync(skill.Id))"
                                  @onkeydown="@(async (e) => { if (e.Key == "Enter" || e.Key == " ") await ToggleFilesAsync(skill.Id); })">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile"
                                         Size="Size.Small"
                                         Style="color:#7B8EA8; vertical-align:middle; font-size:0.85rem;" />
                                <span>@fileCount file@(fileCount == 1 ? "" : "s")</span>
                                <MudIcon Icon="@(isFilesExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                         Size="Size.Small"
                                         Style="color:#7B8EA8; font-size:0.85rem;" />
                            </span>
                            <div class="skill-card-actions" @onclick:stopPropagation="true">
                                <MudTooltip Text="Edit skill">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Style="color:#00E5FF"
                                                   aria-label="@($"Edit {skill.Name}")"
                                                   OnClick="@(() => OpenEditDialog(skill))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete skill">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   aria-label="@($"Delete {skill.Name}")"
                                                   OnClick="@(() => DeleteSkill(skill))" />
                                </MudTooltip>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(skill.Content))
                    {
                        <p class="skill-content-preview">@Truncate(skill.Content, 150)</p>
                    }
                    else
                    {
                        <p class="skill-content-preview no-content">No content defined</p>
                    }

                    <!-- Files Panel (inline expand, uses display:none to avoid MudSelect issues) -->
                    <div class="skill-files-section" style="display:@(isFilesExpanded ? "block" : "none");">
                        <div class="skill-files-header">
                            <MudText Typo="Typo.subtitle2"
                                     Style="color:#7B8EA8; text-transform:uppercase; letter-spacing:0.1em; font-size:0.72rem;">
                                📎 Reference Files
                            </MudText>
                            <div style="display:flex; align-items:center; gap:0.25rem;">
                                @if (isUploadingForSkill)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Style="width:18px; height:18px;" />
                                }
                                <!-- Hidden file input — always in DOM to avoid MudSelect/popover issues -->
                                <InputFile id="@($"file-upload-{skill.Id}")"
                                           OnChange="@((e) => OnFileSelected(e, skill.Id))"
                                           style="display:none"
                                           accept="*/*" />
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Upload"
                                           Style="color:#00E5FF; font-size:0.75rem;"
                                           Disabled="@isUploadingForSkill"
                                           aria-label="@($"Upload file for {skill.Name}")"
                                           OnClick="@(() => TriggerFileUpload(skill.Id))">Upload</MudButton>
                            </div>
                        </div>

                        @if (_filesLoading.Contains(skill.Id))
                        {
                            <div class="file-item">
                                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="70%" />
                                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="20%" />
                            </div>
                        }
                        else if (!_skillFiles.TryGetValue(skill.Id, out var skillFileList) || skillFileList.Count == 0)
                        {
                            <MudText Typo="Typo.caption"
                                     Style="color:#4A5568; font-style:italic; display:block; padding:0.5rem 0;">
                                No reference files yet
                            </MudText>
                        }
                        else
                        {
                            <div class="file-list">
                                @foreach (var file in skillFileList)
                                {
                                    var fileRef = file;
                                    <div class="file-item">
                                        <MudIcon Icon="@GetContentTypeIcon(fileRef.ContentType)"
                                                 Size="Size.Small"
                                                 Style="color:#7B8EA8; flex-shrink:0;" />
                                        <span class="file-name" title="@fileRef.FileName">@fileRef.FileName</span>
                                        <span class="file-size">@FormatFileSize(fileRef.FileSize)</span>
                                        <div class="file-actions">
                                            <MudTooltip Text="Download file">
                                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                               Size="Size.Small"
                                                               Style="color:#00E5FF;"
                                                               aria-label="@($"Download {fileRef.FileName}")"
                                                               OnClick="@(() => DownloadFile(skill.Id, fileRef.Id, fileRef.FileName))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Delete file">
                                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                               Size="Size.Small"
                                                               Color="Color.Error"
                                                               aria-label="@($"Delete {fileRef.FileName}")"
                                                               OnClick="@(() => DeleteFile(skill.Id, fileRef))" />
                                            </MudTooltip>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</MudStack>


