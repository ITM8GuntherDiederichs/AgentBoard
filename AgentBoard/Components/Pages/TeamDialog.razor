@using AgentBoard.Data.Models

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-1">
            <MudTextField T="string"
                          Label="Name"
                          @bind-Value="Model.Name"
                          Required="true"
                          RequiredError="Name is required"
                          MaxLength="200"
                          Counter="200"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          aria-label="Team name" />
            <MudTextField T="string"
                          Label="Description"
                          @bind-Value="Model.Description"
                          Lines="3"
                          MaxLength="2000"
                          Variant="Variant.Outlined"
                          HelperText="Brief summary of this team's purpose"
                          aria-label="Team description" />
            <MudTextField T="string"
                          Label="Team Instructions"
                          @bind-Value="Model.Instructions"
                          Lines="6"
                          Variant="Variant.Outlined"
                          HelperText="Shared guidelines for all agents in this team"
                          aria-label="Team instructions" />

            @* ── Integration ──────────────────────────────────────────────── *@
            <MudDivider />
            <MudText Typo="Typo.caption"
                     Style="color:#00E5FF; text-transform:uppercase; letter-spacing:0.08em; font-family:'Orbitron',sans-serif; font-size:0.7rem;">
                ⚙ Integration
            </MudText>

            @* MudSelect is ALWAYS rendered (never inside @if) — MudBlazor v9 rule *@
            <MudSelect T="IntegrationType"
                       Label="Integration Type"
                       @bind-Value="Model.IntegrationType"
                       Variant="Variant.Outlined"
                       aria-label="Integration type">
                @foreach (var t in Enum.GetValues<IntegrationType>())
                {
                    <MudSelectItem T="IntegrationType" Value="@t">@t.ToString()</MudSelectItem>
                }
            </MudSelect>

            @* RepoUrl — display:none when None to avoid MudSelect @if crash on sibling components *@
            <div style="@(Model.IntegrationType == IntegrationType.None ? "display:none" : "")">
                <MudTextField T="string"
                              Label="Repository URL"
                              @bind-Value="Model.RepoUrl"
                              Variant="Variant.Outlined"
                              HelperText="e.g. https://github.com/org/repo"
                              Placeholder="https://github.com/org/repo"
                              aria-label="Repository URL" />
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" aria-label="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(Model.Name))"
                   aria-label="Save team">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Team Model { get; set; } = new();

    void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    void Cancel() => MudDialog.Cancel();
}
